{
  "name": "ai-augmented-e2e",
  "version": "1.0.0",
  "description": "End-to-end test framework with Playwright + TypeScript, Page Object Model, CI and an AI-augmented test design module.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "ai:generate": "tsx src/ai/generate-tests.ts",
    "lint": "eslint . --ext .ts"
  },
  "keywords": ["qa", "playwright", "typescript", "e2e", "automation", "ai", "testing"],
  "author": "Gabriele Scano",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
